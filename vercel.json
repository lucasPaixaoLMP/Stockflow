{
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/stockflow/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stockflow-api-lucas.fly.dev/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
